{% extends 'base.html.twig' %}

{% block title %}Hello AccountController!{% endblock %}

{% block main %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<h2>Votre profil</h2>

{% if profil is empty %}
    <div class="text-center">
        <a href="{{path('app_profil_new')}}" class="btn btn-warning  ">Alimenter votre profil</a>
    </div>
{% else %}
    <div class="example-wrapper">

    <table class="table">
        <thead>
            <tr>
                
                <th>firstName</th>
                <th>lastName</th>
                <th>email</th>
                <th>Picture</th>
                <th>Description</th>
                <th>DateBirth</th>
                
                <th>actions</th>
            </tr>
        </thead>
        <tbody>

                <tr>
                    {# {{ dump(profil) }} #}

                    <td>{{app.user.firstName}}</td>
                    <td>{{app.user.lastName}}</td>
                    <td>{{app.user.email}}</td>

                    {% for data in profil %}
                        
                    
                    <td> <img src="{{asset('images/' ~ data.picture)}}" alt="Image de profil" class="img-fluid"> </td>
                    <td>{{data.description}}</td>
                    <td>{{data.dateBirth|date('d/M/Y')}}</td>
                    
                    <td>
                        <a href="" class="btn btn-warning">modifier</a>
                    </td>
                    {% endfor %}

                </tr>

        </tbody>
    </table>
</div>
{% endif %}





{% endblock %}
